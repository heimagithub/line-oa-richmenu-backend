# 複製為 .env.test 後填入實際值。.env.test 已被 .gitignore 忽略，請勿提交。
# 跑測試：set -a && source .env.test && set +a && python test.py

# 與部署相同的 JWT_SECRET（用於自簽 access token，跳過 OAuth）
JWT_SECRET=

# 測試用 LINE OA channel 憑證（heima 帳號）
TEST_CHANNEL_SECRET=
TEST_CHANNEL_ACCESS_TOKEN=

